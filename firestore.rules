rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - isApproved: bool (required)
    //   - role: string (required, 'admin'|'user')
    //   - createdAt: number (required)
    //
    // Collection: recipes
    // Document ID: recipeId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - category: string (required)
    //   - creator: string (required)
    //   - lastModified: number (required)
    //   ... other fields
    //
    // Collection: products
    // Document ID: productId
    //
    // Collection: menuPlans
    // Document ID: menuPlanId
    //
    // Collection: settings
    // Document ID: global
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jcbprofesor@gmail.com" && request.auth.token.email_verified == true));
    }

    function isApproved() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true || isAdmin());
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'isApproved', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.isApproved is bool &&
             data.role in ['admin', 'user'];
    }

    function isValidWorkspaceSettings(data) {
      return data.keys().hasAll(['workspaceId', 'categories']) &&
             data.keys().hasOnly(['workspaceId', 'categories', 'categoryConfigs']) &&
             data.workspaceId is string &&
             data.categories is list &&
             data.categories.size() < 50 &&
             (!('categoryConfigs' in data) || data.categoryConfigs is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    function getUserWorkspace() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.get('workspaceId', request.auth.uid) : request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile, but must start as unapproved and 'user' role
      // EXCEPTION: The default admin email is allowed to create itself as approved admin
      allow create: if isOwner(userId) && 
                      (
                        (request.resource.data.isApproved == false && request.resource.data.role == 'user') ||
                        (request.auth.token.email == "jcbprofesor@gmail.com" && request.auth.token.email_verified == true && request.resource.data.role == 'admin' && request.resource.data.isApproved == true)
                      );
      
      // Only admins can approve users or change roles. Users can update their own workspaceId if they accept an invite.
      allow update: if isAdmin() || 
                      (isOwner(userId) && 
                       request.resource.data.isApproved == resource.data.isApproved && 
                       request.resource.data.role == resource.data.role);
      
      allow delete: if isAdmin();
    }

    match /workspace_invites/{inviteId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /workspace_settings/{workspaceId} {
      allow read: if isApproved() && (isAdmin() || workspaceId == getUserWorkspace());
      allow create: if isApproved() && (isAdmin() || (workspaceId == getUserWorkspace() && isValidWorkspaceSettings(request.resource.data)));
      allow update: if isApproved() && (isAdmin() || (workspaceId == getUserWorkspace() && isValidWorkspaceSettings(request.resource.data)));
      allow delete: if isAdmin();
    }

    match /recipes/{recipeId} {
      allow read: if isApproved() && (isAdmin() || resource.data.isPublic == true || resource.data.workspaceId == getUserWorkspace());
      allow create: if isApproved() && (isAdmin() || request.resource.data.workspaceId == getUserWorkspace());
      allow update: if isApproved() && (isAdmin() || (resource.data.workspaceId == getUserWorkspace() && request.resource.data.workspaceId == getUserWorkspace()));
      allow delete: if isApproved() && (isAdmin() || resource.data.workspaceId == getUserWorkspace());
    }

    match /products/{productId} {
      allow read: if isApproved() && (isAdmin() || resource.data.status == 'approved' || resource.data.requestedBy == request.auth.uid);
      allow create: if isApproved() && (isAdmin() || request.resource.data.status == 'pending');
      allow update: if isAdmin() || (isApproved() && resource.data.requestedBy == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /menuPlans/{menuPlanId} {
      allow read: if isApproved() && (isAdmin() || resource.data.workspaceId == getUserWorkspace());
      allow create: if isApproved() && (isAdmin() || request.resource.data.workspaceId == getUserWorkspace());
      allow update: if isApproved() && (isAdmin() || (resource.data.workspaceId == getUserWorkspace() && request.resource.data.workspaceId == getUserWorkspace()));
      allow delete: if isApproved() && (isAdmin() || resource.data.workspaceId == getUserWorkspace());
    }

    match /settings/global {
      allow read: if isAuthenticated(); // Settings might be needed for landing page info
      allow write: if isAdmin();
    }
  }
}
